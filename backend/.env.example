# Copy to .env and fill in. .env is gitignored.

# Groq API key for LLM-generated explanations. Get a free key at https://console.groq.com.
# If unset, the backend will fall back to deterministic flavor-text explanations.
GROQ_API_KEY=

# Optional: override the LLM model used for explanations.
# GROQ_MODEL=llama-3.1-8b-instant

# Optional: override the embedding model (must match the model used to build data/embeddings.npy).
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Comma-separated list of allowed CORS origins (no trailing slash).
# In production, set this to your Vercel URL, e.g. https://what-pokemon-are-you.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: directory containing pokemon.json + embeddings.npy + pokemon_names.json.
# Defaults to ../data in local dev and /app/data in Docker.
# DATA_DIR=
